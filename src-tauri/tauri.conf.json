{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Touchless",
  "version": "0.1.0",
  "identifier": "com.touchless.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Touchless",
        "width": 760,
        "height": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../sidecar.py",
      "../gestures.py",
      "../tracker.py",
      "../hand_detector.py",
      "../cursor_controller.py",
      "../models/hand_landmarker.task",
      "../models/gesture_recognizer.task"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": []
  }
}
